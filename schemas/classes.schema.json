{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "classes.schema.json",
  "title": "Weekly class grid",
  "type": "object",
  "additionalProperties": false,
  "required": ["week", "start", "end", "tracks", "slots"],
  "properties": {
    "week": { "type": "integer", "minimum": 1, "maximum": 10 },
    "start": { "type": "string", "format": "date" },
    "end": { "type": "string", "format": "date" },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "name": { "type": "string", "minLength": 1 }
        }
      }
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["day", "time", "track", "venue"],
        "properties": {
          "day": { "type": "string", "format": "date" },
          "time": {
            "type": "string",
            "pattern": "^([01][0-9]|2[0-3])[.:][0-5][0-9]-([01][0-9]|2[0-3])[.:][0-5][0-9]$"
          },
          "track": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "venue": {
            "oneOf": [
              { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
              {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
              }
            ]
          },
          "note": { "type": "string" }
        }
      }
    }
  }
}
