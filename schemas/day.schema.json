{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "day.schema.json",
  "title": "Daily activities sheet",
  "type": "object",
  "additionalProperties": false,
  "required": ["date", "events"],
  "$defs": {
    "hhmm": {
      "type": "string",
      "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
    },
    "venueList": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
    },
    "timedItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "venues", "start", "end"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "venues": { "$ref": "#/$defs/venueList" },
        "start": { "$ref": "#/$defs/hhmm" },
        "end": { "$ref": "#/$defs/hhmm" },
        "kind": { "type": "string" },
        "note": { "type": "string" },
        "teacher": { "type": "string" }
      }
    }
  },
  "properties": {
    "date": { "type": "string", "format": "date" },
    "library_theme": { "type": "string" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "venues"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "venues": { "$ref": "#/$defs/venueList" },
          "start": { "$ref": "#/$defs/hhmm" },
          "end": { "$ref": "#/$defs/hhmm" },
          "start_text": { "type": "string", "minLength": 1 },
          "after": { "type": "string" },
          "kind": { "type": "string" },
          "note": { "type": "string" }
        },
        "oneOf": [
          { "required": ["start"] },
          { "required": ["start_text"] }
        ]
      }
    },
    "specials": {
      "type": "array",
      "items": { "$ref": "#/$defs/timedItem" }
    },
    "tasters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "venues"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "teacher": { "type": "string" },
          "venues": { "$ref": "#/$defs/venueList" },
          "start": { "$ref": "#/$defs/hhmm" },
          "end": { "$ref": "#/$defs/hhmm" },
          "note": { "type": "string" }
        }
      }
    },
    "talks": {
      "type": "array",
      "items": { "$ref": "#/$defs/timedItem" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
