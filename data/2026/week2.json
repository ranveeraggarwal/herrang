  "specials": [
    {
      "title": "Bike Ride to Haberödal (Church)",
      "detail": "Meet at the Bike Shop. Come along to discover places around the camp.",
      "date": "2026-07-15",
      "start": "11:00",
      "kind": "special"
    },
    {
      "title": "Nature and Culture Hike",
      "detail": "Meet up outside of Roseland. What is Herräng beyond the dance camp? On this hike we will both explore local flora/fauna as well as try to learn a bit more about the town's history together by walking along the beautiful \"culture trail\". Hike is approximately 6–7 km. Bring your water bottle, a swimsuit (optional) and a positive attitude! :D",
      "date": "2026-07-15",
      "start": "11:00",
      "end": "13:00",
      "venues": ["rb"],
      "kind": "special"
    },
    {
      "title": "Power Yoga",
      "detail": "Anyone (beginner or not) up for a physical, energetical and dynamic yoga class! Led by two instructors offering hands-on assisting.",
      "date": "2026-07-15",
      "start": "12:00",
      "end": "13:00",
      "venues": ["fh"],
      "kind": "taster"
    },
    {
      "title": "Hamilton Singalong",
      "detail": "With an introduction by Christi Jay Wells.",
      "date": "2026-07-15",
      "start": "12:00",
      "end": "14:00",
      "venues": ["lb"],
      "kind": "social"
    },
    {
      "title": "The Art of Taking a Nap",
      "detail": "Meet in front of the Lindy Hop shop. Learn the tips for great naps and the best spots for it around Herräng. Suitable for everyone who loves napping and/or wants to get better at it. Don't bring coffee!",
      "date": "2026-07-15",
      "start": "13:00",
      "end": "13:50",
      "kind": "special"
    },
    {
      "title": "Barbara Billups & Sugar Sullivan",
      "detail": "Special class for everyone, all tracks.",
      "date": "2026-07-15",
      "start": "14:00",
      "end": "15:10",
      "venues": [
        "fh",
        "db"
      ],
      "kind": "special"
    },
    {
      "title": "Dance Trading",
      "detail": "We meet up have an exchange of different dances. As hosts we offer folkdances from the Middle East, Sweden and Indonesia. We would like someone who can teach capoeira or other dances that people request.",
      "date": "2026-07-15",
      "start": "14:00",
      "end": "15:00",
      "venues": ["rb"],
      "kind": "social"
    },
    {
      "title": "Instant Theatre (Improvisation)",
      "detail": "Within one hour we are going to invent a story and act together in an Instant Theatre play. There are only a few rules. All that's needed is you guys. Everything is possible! The second part invites you to transform the story into music, dance or maybe a painting or a podcast.",
      "date": "2026-07-15",
      "start": "14:00",
      "end": "16:00",
      "venues": ["pb"],
      "kind": "special"
    },
    {
      "title": "Costume Construction for Friday Party",
      "detail": "Grass area in front of the Lindy Hop shop, or the Exhibition Room if it rains.",
      "date": "2026-07-15",
      "start": "14:00",
      "end": "16:00",
      "kind": "special"
    },
    {
      "title": "Sound Journey",
      "date": "2026-07-15",
      "start": "15:10",
      "end": "16:40",
      "venues": ["fh"],
      "kind": "special"
    },
    {
      "title": "Movie Afternoon: The Hunchback of Notre Dame",
      "detail": "Klubben. We will celebrate the 30th anniversary of the movie The Hunchback of Notre Dame by watching the Disney movie.",
      "date": "2026-07-15",
      "start": "15:10",
      "end": "16:40",
      "kind": "special"
    },
    {
      "title": "Surströmming",
      "detail": "Meet up in front of Folketshus, to go by the lake.",
      "date": "2026-07-15",
      "start": "16:00",
      "venues": ["fh"],
      "kind": "special"
    },
    {
      "title": "Sieste Musicale / Quiet Concert",
      "detail": "Meet in front of ICP, in the meadows near the school area. Herräng can be an overstimulating place – so join us for some soft live music on the meadow (close to school area) to unwind and reflect. Bring your journals, painting and craft supplies, blankets and your frazzled nervous systems. No talking / only whispering allowed. Bring your own pillows, mats or blankets :)",
      "date": "2026-07-15",
      "start": "16:00",
      "end": "17:00",
      "kind": "special"
    },
    {
      "title": "Tango Class 2 Levels (Introduction & Beginners)",
      "detail": "Beginners class + milonga time. Come to learn some basics, and experienced dancers can come to social dance.",
      "date": "2026-07-15",
      "start": "16:40",
      "end": "17:50",
      "venues": ["db"],
      "kind": "taster"
    },
    {
      "title": "Afternoon Run",
      "detail": "Let's run together in the forest around the camp. Duration and pace to be determined together.",
      "date": "2026-07-15",
      "start": "17:00",
      "end": "18:00",
      "venues": ["fh"],
      "kind": "special"
    },
    {
      "title": "Tango Practice (Milonga)",
      "date": "2026-07-15",
      "start": "18:00",
      "end": "19:10",
      "venues": ["fh"],
      "kind": "social"
    },
    {
      "title": "Introduction to International Sign (IS)",
      "detail": "Klubben. How can we communicate on the dance floor without using spoken language? How can we connect with one another through eye contact, body language, and presence? Led by a Deaf facilitator who uses International Sign (IS), this workshop offers a fun and accessible introduction to this visual means of communication in an intercultural setting that encourages connection and exchange. Through interactive activities and practical situations, participants will learn useful signs to introduce themselves, meet new people, invite someone to dance, show their impressions of a dance event, or simply chat between dances. Beyond learning signs, the workshop is also an opportunity to discover Deaf culture and experience another way of being together, where eye contact, facial expressions, and attentive interaction play a central role. An invitation to broaden your language, your curiosity, and your way of building community on the dance floor. Open to everyone. No previous knowledge is required!",
      "date": "2026-07-15",
      "start": "18:00",
      "end": "19:10",
      "kind": "special"
